"""
FNO pipeline-parallelism workflow: profile → solve → benchmark.

Usage (from repo root):
    # Full pipeline for one setup (profile → solve → benchmark):
    snakemake -s fno/Snakefile --config model=base remat=F-StageRemat scheduler=zbh1 mem=72000

    # Only solve (no GPU benchmark):
    snakemake -s fno/Snakefile --config model=base remat=F-StageRemat scheduler=zbh1 mem=72000 step=solve

    # Memory comparison (ILP estimates vs measured):
    snakemake -s fno/Snakefile --config model=base remat=F-StageRemat scheduler=zbh1 mem=72000 step=memory

    # Multi-wave (e.g. zbv with 2 waves):
    snakemake -s fno/Snakefile --config model=base remat=NoRemat scheduler=zbv waves=2 mem=72000

    # Dry run:
    snakemake -s fno/Snakefile --config model=base remat=F-StageRemat scheduler=zbh1 mem=72000 -n

CLI parameters:
    model:      config name in fno/configs/ (default: base)
    remat:      NoRemat, Uni-F-Remat, Uni-FB-Remat,
                F-StageRemat, FB-StageRemat, F-Greedy, FB-Greedy
    scheduler:  1f1b, zbh1, zbh2, zbv, afab, hanayo, ...
    waves:      integer (default: 1; zbv typically uses 2)
    mem:        GPU memory budget in MB (required); for step=sweep use
                start:step:end (e.g. 40000:5000:80000) or comma-separated list
    step:       solve | benchmark | memory | sweep (default: benchmark)

File structure:
    fno/
      configs/{model}.json                             <- model + deployment params
      profiling.py                                     <- profiling script (1 GPU)
      profile_comms.py                                 <- communication profiling (2 GPUs)
      benchmark.py                                     <- benchmarking script (ngpus GPUs)
    results/fno/{model}/
      profile_{nstages}stages.json                     <- profiled per-stage compute stats (shared)
      profile_{nstages}stages_comms.json               <- profile + measured Tcomm (shared)
      mem{mem}/solutions/{method}.json                 <- ILP / heuristic solution
      mem{mem}/benchmarks/{method}.json                <- measured execution time + peak memory
      mem{mem}/memory/{method}.json                    <- merged ILP + measured memory evolution
"""

import json
import functools


# ---------------------------------------------------------------------------
# Helpers
# ---------------------------------------------------------------------------

@functools.lru_cache(maxsize=None)
def load_fno_config(config_name):
    with open(f"fno/configs/{config_name}.json") as f:
        return json.load(f)


def parse_method(method_str):
    """Parse 'ilp_fwd.zbh1.1w' -> ('ilp_fwd', 'zbh1', 1)."""
    remat, scheduler, waves_str = method_str.rsplit(".", 2)
    return remat, scheduler, int(waves_str.rstrip("wW"))


def nstages_for_method(config_name, method_str):
    cfg = load_fno_config(config_name)
    _, _, waves = parse_method(method_str)
    return waves * cfg["ngpus"]


# ---------------------------------------------------------------------------
# Wildcard constraints
# ---------------------------------------------------------------------------

wildcard_constraints:
    fno_config=r"[a-zA-Z0-9_-]+",
    nstages=r"\d+",
    memgpu=r"\d+",
    method=r"[a-zA-Z0-9_.\-]+",


# ---------------------------------------------------------------------------
# Targets
# ---------------------------------------------------------------------------

MODEL = config.get("model", "base")
REMAT = config.get("remat", None)
SCHEDULER = config.get("scheduler", None)
WAVES = int(config.get("waves", 1))
MEM = config.get("mem", None)
STEP = config.get("step", "benchmark")  # "solve", "benchmark", or "memory"

os.environ["PYTORCH_CUDA_ALLOC_CONF"] = "expandable_segments:True" # FNO has high fragmentation
os.environ["PYTORCH_ALLOC_CONF"] = "expandable_segments:True"

_missing = [name for name, val in [("remat", REMAT), ("scheduler", SCHEDULER), ("mem", MEM)] if not val]
if _missing:
    raise ValueError(
        f"Missing required config: {', '.join(_missing)}.\n"
        "Example: snakemake -s fno/Snakefile --config model=base remat=F-StageRemat scheduler=zbh1 mem=72000"
    )

METHOD = f"{REMAT}.{SCHEDULER}.{WAVES}w"

def _parse_mem_list(mem_str):
    """Parse '40000:5000:80000' (start:step:end) or '40000,50000,60000'."""
    mem_str = str(mem_str)
    if ":" in mem_str:
        start, step, end = map(int, mem_str.split(":"))
        return list(range(start, end + 1, step))
    if "," in mem_str:
        return [int(m) for m in mem_str.split(",")]
    return [int(mem_str)]

_STEP_TO_DIR = {"solve": "solutions", "benchmark": "benchmarks", "memory": "memory"}

if STEP == "sweep":
    rule all:
        input:
            expand(
                f"results/fno/{MODEL}/mem{{memgpu}}/benchmarks/{METHOD}.json",
                memgpu=_parse_mem_list(MEM),
            )
        output:
            f"results/fno/{MODEL}/sweep_{METHOD}.json"
        run:
            import json
            summary = {}
            for path in input:
                mem = int(path.split("/mem")[1].split("/")[0])
                with open(path) as f:
                    data = json.load(f)
                summary[mem] = data
            with open(output[0], "w") as f:
                json.dump(summary, f, indent=2)
            print(json.dumps(summary, indent=2))
else:
    rule all:
        input:
            f"results/fno/{MODEL}/mem{MEM}/{_STEP_TO_DIR[STEP]}/{METHOD}.json"


# ---------------------------------------------------------------------------
# Rules
# ---------------------------------------------------------------------------

rule profile:
    """Profile per-stage compute times and memory. Requires 1 GPU."""
    input:
        "fno/configs/{fno_config}.json",
    output:
        "results/fno/{fno_config}/profile_{nstages}stages.json",
    shell:
        "python fno/profiling.py "
        "-c {input} -n {wildcards.nstages} -o {output} -i 30"


rule profile_comms:
    """Measure inter-GPU communication latency. Requires 2 GPUs."""
    input:
        "results/fno/{fno_config}/profile_{nstages}stages.json",
    output:
        "results/fno/{fno_config}/profile_{nstages}stages_comms.json",
    shell:
        "torchrun --standalone --nproc-per-node=2 "
        "fno/profile_comms.py -c {input} --output {output}"


rule solve:
    """Solve ILP or compute baseline remat strategy. CPU only."""
    input:
        profile=lambda wc: "results/fno/{fno_config}/profile_{nstages}stages_comms.json".format(
            fno_config=wc.fno_config,
            nstages=nstages_for_method(wc.fno_config, wc.method),
        ),
        config="fno/configs/{fno_config}.json",
    output:
        "results/fno/{fno_config}/mem{memgpu}/solutions/{method}.json",
    params:
        ngpus=lambda wc: load_fno_config(wc.fno_config)["ngpus"],
        nmb=lambda wc: load_fno_config(wc.fno_config)["nmb"],
    shell:
        "python pipeline-ilps/runall.py "
        "--config {input.config} "
        "--profiling {input.profile} "
        "--method {wildcards.method} "
        "--processors {params.ngpus} "
        "--mem {wildcards.memgpu} "
        "--nmb {params.nmb} "
        "--time-limit 600 "
        "-o {output}"


rule benchmark:
    """Benchmark a solved method with ELF. Requires ngpus GPUs. Skips infeasible solutions."""
    input:
        solution="results/fno/{fno_config}/mem{memgpu}/solutions/{method}.json",
    output:
        "results/fno/{fno_config}/mem{memgpu}/benchmarks/{method}.json",
    params:
        ngpus=lambda wc: load_fno_config(wc.fno_config)["ngpus"],
    resources:
        gpus=lambda wc: load_fno_config(wc.fno_config)["ngpus"],
    run:
        import json
        with open(input.solution) as f:
            sol = json.load(f)
        method_sol = sol.get("solutions", {}).get(wildcards.method, sol)
        if "error" in method_sol:
            print(f"Skipping benchmark for {wildcards.method}: {method_sol['error']}")
            with open(output[0], "w") as f:
                json.dump({"skipped": True, "reason": method_sol["error"]}, f, indent=2)
        else:
            config_file = f"fno/configs/{wildcards.fno_config}.json"
            error_msg = '{{\"error\": \"benchmark_failed\"}}'
            shell(
                "torchrun --standalone --nproc-per-node={params.ngpus} "
                "fno/benchmark.py "
                "--solution-file {input.solution} "
                "--config-file " + config_file + " "
                "--output-file {output} "
                "--solution-type {wildcards.method} "
                '|| echo \'' + error_msg + '\' > {output}'
            )

# ---------------------------------------------------------------------------
# Memory comparison workflow (step=memory)
# ---------------------------------------------------------------------------

rule simulate_memory:
    """Simulate memory evolution from ILP solution. CPU only. Skips infeasible solutions."""
    input:
        profile=lambda wc: "results/fno/{fno_config}/profile_{nstages}stages_comms.json".format(
            fno_config=wc.fno_config,
            nstages=nstages_for_method(wc.fno_config, wc.method),
        ),
        solution="results/fno/{fno_config}/mem{memgpu}/solutions/{method}.json",
    output:
        "results/fno/{fno_config}/mem{memgpu}/memory/ilp/{method}.json",
    run:
        import json
        with open(input.solution) as f:
            sol = json.load(f)
        method_sol = sol.get("solutions", {}).get(wildcards.method, sol)
        if "error" in method_sol:
            print(f"Skipping simulation for {wildcards.method}: {method_sol['error']}")
            with open(output[0], "w") as f:
                json.dump({"skipped": True, "reason": method_sol["error"]}, f, indent=2)
        else:
            shell(
                "python pipeline-ilps/simulate_memory.py "
                "--profiling-file {input.profile} "
                "--solution-file {input.solution} "
                "--solution-type {wildcards.method} "
                "--mem {wildcards.memgpu} "
                "-o {output}"
            )


rule benchmark_memory:
    """Benchmark with detailed per-op memory tracking. Requires ngpus GPUs and ELF_MEMORY=1."""
    input:
        solution="results/fno/{fno_config}/mem{memgpu}/solutions/{method}.json",
    output:
        stats="results/fno/{fno_config}/mem{memgpu}/memory/measured/{method}.json",
    params:
        ngpus=lambda wc: load_fno_config(wc.fno_config)["ngpus"],
    run:
        import json
        with open(input.solution) as f:
            sol = json.load(f)
        method_sol = sol.get("solutions", {}).get(wildcards.method, sol)
        if "error" in method_sol:
            print(f"Skipping memory benchmark for {wildcards.method}: {method_sol['error']}")
            with open(output.stats, "w") as f:
                json.dump({"skipped": True, "reason": method_sol["error"]}, f, indent=2)
        else:
            shell(
                "ELF_MEMORY=1 torchrun --standalone --nproc-per-node={params.ngpus} "
                "fno/benchmark.py "
                "--solution-file {input.solution} "
                "--config-file {input.solution} "
                "--output-file /dev/null "
                "--solution-type {wildcards.method} "
                "--detailed-stats-file {output.stats}"
            )


rule merge_memory:
    """Merge ILP estimates and measured memory stats for plotting."""
    input:
        ilp="results/fno/{fno_config}/mem{memgpu}/memory/ilp/{method}.json",
        measured="results/fno/{fno_config}/mem{memgpu}/memory/measured/{method}.json",
    output:
        "results/fno/{fno_config}/mem{memgpu}/memory/{method}.json",
    run:
        import json
        with open(input.ilp) as f:
            ilp = json.load(f)
        with open(input.measured) as f:
            measured = json.load(f)
        merged = {"ilp_estimates": ilp, "measured_data": measured}
        with open(output[0], "w") as f:
            json.dump(merged, f, indent=2)


# ---------------------------------------------------------------------------
# Utilities
# ---------------------------------------------------------------------------

rule clean:
    """Remove all generated results for a model config (all memory budgets)."""
    params:
        results_dir=f"results/fno/{MODEL}",
    shell:
        "rm -rfI {params.results_dir}"
