Bootstrap: docker
From: nvcr.io/nvidia/pytorch:24.09-py3

%post
    # Update and install essential packages
    apt-get update && apt-get install -y \
        git \
        wget \
        curl \
        build-essential \
        cmake \
        gcc

    pip install --force-reinstall --no-cache-dir --index https://download.pytorch.org/whl/cu124\
        torch==2.4.0 \
        torchvision
    # Install additional Python packages
    pip install --no-cache-dir \
     numpy matplotlib pandas wandb tensorboardX datasets transformers tensorboard timm pytest pyyaml tqdm networkx huggingface-hub ruff


    # METIS
    git clone https://github.com/KarypisLab/GKlib.git
    cd GKlib
    make config prefix=/usr/local
    make && make install
    cd ..
    git clone https://github.com/KarypisLab/METIS.git
    cd METIS
    make config prefix=/usr/local
    make install

    # Nsight Systems

    # Get the debian package
    wget https://developer.nvidia.com/downloads/assets/tools/secure/nsight-systems/2024_6/nsight-systems-2024.6.1_2024.6.1.90-1_arm64.deb ;
    # Extract
    ar x nsight-systems-2024.6.1_2024.6.1.90-1_arm64.deb ;
    # Extract the important files
    tar xvzf data.tar.gz ;
    # Remove package metadata
    rm debian-binary control.tar.gz nsight-systems-2024.6.1_2024.6.1.90-1_arm64.deb ;
    # Add binary to path. Replace ${pwd} by the correct path if you add it in .bashrc
    export PATH="$(pwd)/opt/nvidia/nsight-systems/2024.6.1/bin":$PATH ;
    # Check installation
    nsys --version

