Bootstrap: docker
From: nvcr.io/nvidia/pytorch:24.09-py3

%post
    # Update and install essential packages
    apt-get update && apt-get install -y \
        git \
        wget \
        curl \
        build-essential \
        cmake \
        gcc

    pip install --index https://download.pytorch.org/whl/cu124\
        torch==2.4.0 \
        torchvision
    # Install additional Python packages
    pip install \
     numpy matplotlib pandas wandb tensorboardX datasets transformers tensorboard timm pytest pyyaml tqdm networkx huggingface-hub ruff scons


    # METIS
    git clone https://github.com/KarypisLab/GKlib.git
    cd GKlib
    make config prefix=/usr/local
    make && make install
    cd ..
    git clone https://github.com/KarypisLab/METIS.git
    cd METIS
    make config prefix=/usr/local
    make install
    cd ..

    # Nsight Systems

    # Get the debian package
    wget https://developer.nvidia.com/downloads/assets/tools/secure/nsight-systems/2025_2/nsight-systems-2025.2.1_2025.2.1.130-1_amd64.deb;
    # Extract
    ar x nsight-systems-2025.2.1_2025.2.1.130-1_amd64.deb ;
    # Extract the important files
    tar xvzf data.tar.gz ;
    # Remove package metadata
    rm debian-binary control.tar.gz nsight-systems-2025.2.1_2025.2.1.130-1_amd64.deb ;
    # Add binary to path. Replace ${pwd} by the correct path if you add it in .bashrc
    export PATH="$(pwd)/opt/nvidia/nsight-systems/2024.7.1/bin":$PATH ;
    # Check installation
    nsys --version

    ## dagP
    git clone https://github.com/GT-TDAlab/dagP.git
    cd dagP
    echo "import os ; CC = 'gcc' ; CXX = 'g++' ; LINK = 'g++' ; extincludes = '/usr/local/include:' ; extlibs = 'metis' ; extlibpath = '/usr/local/lib'" > config.py
    scons
    cp exe/rMLGP /usr/local/bin/
    cd ..

